#!/bin/bash
# 脚本功能：基于 cliphist 和 fzf 的高级剪贴板 TUI 工具。
# 1. 自动过滤和美化剪贴板历史列表（支持视频、图片、QQ/微信富文本等内容）。
# 2. 结合 Kitty icat 或 chafa 实现剪贴板内容的实时预览（支持生成视频缩略图）。
# 3. 智能解析剪贴板数据，支持原格式重新复制或提取有效路径复制。
# 4. 支持快捷键 (Ctrl+O / Ctrl+E) 直接调用系统默认工具打开剪贴板中的图片或视频文件。
# 5. 支持快捷键 (Ctrl+R) 手动刷新剪贴板列表，Ctrl+X删除条目，Alt+X 一键清空剪贴板历史。

# 确保缓存目录存在
export CACHE_DIR="$HOME/.cache/cliphist-tui"
# 兼容
[ -d "$HOME/.cache/shorinclip" ] && [ ! -d "$CACHE_DIR" ] && mv "$HOME/.cache/shorinclip" "$CACHE_DIR" 2>/dev/null
mkdir -p "$CACHE_DIR"
# 确保默认shell为bash
export SHELL=$(command -v bash)

# 颜色变量，适配matugen配色
export C_TERTIARY='\x1b[1;35m'
export C_PRIMARY='\x1b[1;34m'
export C_CYAN='\x1b[1;36m'
export C_RESET='\x1b[0m'

command -v ffmpegthumbnailer >/dev/null 2>&1 && export HAS_FFMPEG=1 || export HAS_FFMPEG=0
command -v xxh128sum >/dev/null 2>&1 && export HAS_XXHASH=1 || export HAS_XXHASH=0

# 检查是否支持kitty协议
check_kitty_icat() {
  local kitty_cache="/dev/shm/shorinclip_kitty_${TERM}_${WEZTERM_EXECUTABLE:-0}"
  if [ -f "$kitty_cache" ]; then
    source "$kitty_cache"
    return
  fi

  export ENABLE_ICAT=0
  export IS_NATIVE_KITTY=0

  # 1. 为kitty终端单独做判断
  if [ "$TERM" = "xterm-kitty" ]; then
    export ENABLE_ICAT=1
    export IS_NATIVE_KITTY=1
    echo "export ENABLE_ICAT=1; export IS_NATIVE_KITTY=1" > "$kitty_cache"
    return
  fi

  # 2. 虽然WezTerm支持kitty协议，但似乎有些问题，禁用
  if [ -n "$WEZTERM_EXECUTABLE" ]; then
    ENABLE_ICAT=0
    echo "export ENABLE_ICAT=0; export IS_NATIVE_KITTY=0" > "$kitty_cache"
    return
  fi

  # 3. 通过转义序列判断
  (
    # 构造查询序列
    local query_id query_code fence_code expected
    query_id=$RANDOM
    query_code=$(printf "\033_Gi=%d,s=1,v=1,a=q,t=d,f=24;AAAA\033\\" "$query_id")
    expected=$(printf "\033_Gi=%d;OK\033\\" "$query_id")
    # 哨兵，确保不支持的终端也能返回内容
    fence_code=$(printf "\033[c")

    # 设置终端为非规范模式，单字符读取，超时 0.5 秒
    local stty_orig
    stty_orig=$(stty -g)
    trap "stty '$stty_orig'" EXIT
    stty -echo -icanon min 0 time 1

    printf "%s%s" "$query_code" "$fence_code" >/dev/tty

    local response=""
    ret=0
    while true; do
      IFS= read -r -N 1 char || {
        [ -z "$char" ] && break
      }

      response+="$char"

      # 匹配查询响应 \033_Gi=ID;OK\033\
      if [[ "$response" == *"$expected"* ]]; then
        ret=1
        # 持续读取避免残留字符
      fi

      # 匹配哨兵响应 \033[c
      if [[ "$response" == *$'\033['*'c' ]]; then
        break
      fi

      # 防止响应过大
      if [ ${#response} -gt 1024 ]; then
        break
      fi
    done

    exit $ret
  )
  ENABLE_ICAT=$?
  export ENABLE_ICAT
  echo "export ENABLE_ICAT=$ENABLE_ICAT; export IS_NATIVE_KITTY=$IS_NATIVE_KITTY" > "$kitty_cache"
}
check_kitty_icat

# ============================
# 设置图片 preview命令
# ============================
_preview() {
  # 导入文件
  local file="$1"
  # 文件的mime类型
  local mime=$(file -b --mime-type "$file")
  # 如果支持kitty协议的话
  if [ "$ENABLE_ICAT" = "1" ]; then
    # 如果是gif并且是原生kitty终端的话用kitty icat显示gif图片（不过窗口过小的时候貌似无法完整显示）
    if [ "$IS_NATIVE_KITTY" = "1" ] && [[ "$mime" =~ "gif" ]]; then
      kitty icat --transfer-mode=file --image-id=10 \
        --place="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}@0x0" \
        "$file" </dev/tty
      return
    fi
    # 情况用chafa -f kitty --animate=off 显示静态预览图（因为他们对gif的支持不好）
    chafa -f kitty --animate=off --size="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}" "$file"

    # 不支持kitty协议的终端用chafa自动选择合适的协议显示静态预览图
  else
    chafa --animate=off --size="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}" "$file"
  fi
}
export -f _preview

_preview_video() {
  local vid_file="$1"
  local video_hash=$(echo "$vid_file" | hash_calc)
  local thumb_file="$CACHE_DIR/$video_hash.png"
  if [ ! -f "$thumb_file" ]; then
      if [ "$HAS_FFMPEG" = "1" ]; then
       ffmpegthumbnailer -i "$vid_file" -o "$thumb_file" -s 480 -t 0 >/dev/null 2>&1
      fi
  fi
  if [ -s "$thumb_file" ]; then
     _preview "$thumb_file"
   else
       echo "Video: $vid_file (No thumbnail)"
   fi
}
export -f _preview_video

# 过滤无法复制粘贴的信息
filter_clip_list() {
    grep -a -viE "[[:space:]].*<html.*\[表情\]"
}
export -f filter_clip_list


# 美化列表
format_clip_list() {
  sed -E \
    -e "s/(\t).*\.(mp4|mkv|webm|avi|mov|flv|wmv)$/\1${C_TERTIARY}[VIDEO]File.\2${C_RESET}/;t" \
    -e "s/(\t)file:\/\/.*\.(mp4|mkv|webm|avi|mov|flv|wmv)$/\1${C_TERTIARY}[VIDEO]Url.\2${C_RESET}/;t" \
    -e "s/(\t).*QQRich[E]ditFormat.*EditElement type=\"[7]\".*/\1${C_TERTIARY}[VIDEO_HTML]QQ${C_RESET}/;t" \
    -e "s/(\t).*sr[c]=\"file:\/\/.*[qQ][qQ].*/\1${C_PRIMARY}[IMG_HTML]QQ${C_RESET}/;t" \
    -e "s/(\t)file:\/\/.*xwechat.*temp.*/\1${C_PRIMARY}[IMG_URL]WeChat${C_RESET}/;t" \
    -e "s/(\t)file:\/\/.*\.gif$/\1${C_PRIMARY}[IMG]Url.gif${C_RESET}/;t" \
    -e "s/(\t)file:\/\/.*\.(png|jpg|jpeg|webp|bmp)$/\1${C_TERTIARY}[IMG]Url.\2${C_RESET}/;t" \
    -e "s/(\t)file:\/\/.*\.config\/QQ\/.*/\1${C_PRIMARY}[IMG_URL]QQ${C_RESET}/;t" \
    -e "s/(\t)file:\/\/.*/\1${C_CYAN}[URL]File${C_RESET}/;t" \
    -e "s/(\t)\/.*\.gif$/\1${C_PRIMARY}[IMG]Path.gif${C_RESET}/;t" \
    -e "s/(\t)\/.*\.(png|jpg|jpeg|webp|bmp)$/\1${C_TERTIARY}[IMG]Path.\2${C_RESET}/;t" \
    -e "s/\[\[ binary data .* (png|jpg|jpeg|gif|webp) .*\]\]/${C_TERTIARY}[IMG]Bin.\1${C_RESET}/;t" \
    -e "s/\[\[ binary data .* \]\]/${C_CYAN}[BINARY]${C_RESET}/"
}
export -f format_clip_list

# 导入fzf前的处理,添加序号
add_num() {
  awk -F '\t' '{printf "%s\t\x1b[90m%-2d \x1b[0m%s\n", $1, NR, $2}'
}
export -f add_num

hash_calc(){
  if [ "$HAS_XXHASH" = "1" ]; then
    xxh128sum | cut -d" " -f1
  else
    md5sum | cut -d" " -f1
  fi
}
export -f hash_calc

# 直接打开剪贴板中的媒体文件
open_selection() {
  local input="$1"
  local tmp_open=$(mktemp /dev/shm/shorinclip_open.XXXXXX 2>/dev/null || mktemp)
  trap 'rm -f "$tmp_open" 2>/dev/null' EXIT RETURN
  echo "$input" | cliphist decode > "$tmp_open"

  local mime=$(file -b --mime-type "$tmp_open")
  local decoded=$(cat "$tmp_open")

  # Python 工具：用于 URL 解码
  url_decode() {
    printf '%b' "${1//%/\\x}"
  }

  # 检测文件是否为视频，如果有mpv则带有app-id打开，否则回退到xdg-open
  smart_open() {
    local file_path="$1"
    local file_mime=$(file -b --mime-type "$file_path")
    
    # 如果是视频并且安装了mpv
    if [[ "$file_mime" =~ video ]] && command -v mpv >/dev/null 2>&1; then
      mpv --wayland-app-id="floating-mpv" "$file_path" >/dev/null 2>&1 & disown
    else
      xdg-open "$file_path" >/dev/null 2>&1 & disown
    fi
  }

  # 1. 二进制图片 -> 写入缓存再打开
  if [[ "$mime" =~ image ]]; then
    local img_hash=$(hash_calc < "$tmp_open")
    local ext="${mime#*/}"
    local cache_file="$CACHE_DIR/$img_hash.$ext"
    if [ ! -f "$cache_file" ]; then
      cp "$tmp_open" "$cache_file"
    fi
    xdg-open "$cache_file" >/dev/null 2>&1 & disown

  # 2. QQ HTML -> 提取路径打开 
  elif [ "$mime" = "text/html" ] && [ -f "$(echo "$decoded" | grep -a -oP '^<img sr[c]="file://\K[^"]+' | head -n 1)" ]; then
    local qq_src=$(echo "$decoded" | grep -a -oP "^<img sr[c]=\"file://\K[^\"]+" | head -n 1)
    xdg-open "$qq_src" >/dev/null 2>&1 & disown

  # QQ 视频富文本 -> 提取路径打开 
  elif echo "$decoded" | grep -a -q "QQRich[E]ditFormat" && echo "$decoded" | grep -a -q 'EditElement type="[7]"' && [ -f "$(echo "$decoded" | grep -a -oP 'filepat[h]="\K[^"]+' | head -n 1)" ]; then
    local qq_vid_src=$(echo "$decoded" | grep -a -oP 'filepat[h]="\K[^"]+' | head -n 1)
    smart_open "$qq_vid_src"

  # 3. file:// 协议路径 -> 解码后打开
  elif [[ "$decoded" == file://* ]]; then
    local raw_path="${decoded#file://}"
    raw_path=$(url_decode "$raw_path")
    if [ -e "$raw_path" ]; then
      smart_open "$raw_path"
    else
      notify-send "Open Error" "File does not exist: $raw_path"
    fi

  # 4. 绝对路径 -> 直接打开
  elif [[ "$decoded" == /* ]] && [ -e "$decoded" ]; then
    smart_open "$decoded"

  else
    return 0
  fi
}
export -f open_selection

# 复制前的处理，对不同数据采取不同的处理方式
copy_selection() {
  #获取fzf选择的项目
  local input="$1"
  local tmp_copy=$(mktemp /dev/shm/shorinclip_copy.XXXXXX 2>/dev/null || mktemp)
  trap 'rm -f "$tmp_copy" 2>/dev/null' EXIT RETURN
  echo "$input" | cliphist decode > "$tmp_copy"

  # 提取项目id
  local id=$(echo "$input" | cut -f1)
  # 获取decode内容
  local decoded=$(cat "$tmp_copy")
  # 获取mime类型
  local mime=$(file -b --mime-type "$tmp_copy")

  # Python 工具：用于 URL 编码 (处理路径中的中文和空格)
  url_encode() {
    python -c "import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1]))" "$1"
  }

  # 1. 二进制图片 -> 直接复制图片数据
  if [[ "$mime" =~ image ]]; then
    # 直接复制
    cat "$tmp_copy" | wl-copy
    notify-send "Copied Image" "ID: $id"

  # 2. QQ HTML -> 提取路径 -> 存入缓存 -> 复制 file:// 缓存路径 (验证文件有效性，无效则降级)
  elif [ "$mime" = "text/html" ] && [ -f "$(echo "$decoded" | grep -a -oP '^<img sr[c]="file://\K[^"]+' | head -n 1)" ]; then
    local qq_src=$(echo "$decoded" | grep -a -oP "^<img sr[c]=\"file://\K[^\"]+" | head -n 1)
    local encoded_path=$(url_encode "$qq_src")
    echo "file://$encoded_path" | wl-copy --type text/uri-list
    notify-send "Copied QQ Link" "Src: $qq_src"

  # QQ 视频富文本 -> 提取路径 -> 复制 file:// 链接 
  elif echo "$decoded" | grep -a -q "QQRich[E]ditFormat" && echo "$decoded" | grep -a -q 'EditElement type="[7]"' && [ -f "$(echo "$decoded" | grep -a -oP 'filepat[h]="\K[^"]+' | head -n 1)" ]; then
    local qq_vid_src=$(echo "$decoded" | grep -a -oP 'filepat[h]="\K[^"]+' | head -n 1)
    local encoded_path=$(url_encode "$qq_vid_src")
    echo "file://$encoded_path" | wl-copy --type text/uri-list
    notify-send "Copied QQ Video Link" "Path: $qq_vid_src"

  # 4. file:// 协议路径 -> 直接复制为文件链接
  elif [[ "$decoded" == file://* ]]; then
    echo "$decoded" | wl-copy --type text/uri-list
    notify-send "Copied File Link" "$decoded"

  # 3. 绝对路径 -> 转 file:// -> 复制为URL链接
  elif [[ "$decoded" == /* ]] && [ -e "$decoded" ]; then
    local encoded_path=$(url_encode "$decoded")
    echo "file://$encoded_path" | wl-copy --type text/uri-list
    notify-send "Copied File Path" "$decoded"

  # 5. 其他 -> 普通文本复制 
  else
    cat "$tmp_copy" | wl-copy
  fi
  # 避免出现重复内容
  echo "$input" | cliphist delete 
}
export -f copy_selection

# 自动刷新机制
FZF_PORT=$(shuf -i 10000-60000 -n 1)
RELOAD_CMD="cliphist list | filter_clip_list | format_clip_list | add_num"
wl-paste --watch bash -c "kill -9 \$(cat \"/dev/shm/shorinclip_reload_${FZF_PORT}.pid\" 2>/dev/null) 2>/dev/null; (sleep 0.15; curl -s -X POST -d 'reload($RELOAD_CMD)' http://localhost:$FZF_PORT) & echo \$! > \"/dev/shm/shorinclip_reload_${FZF_PORT}.pid\"" >/dev/null 2>&1 &
WATCH_PID=$!
trap "kill $WATCH_PID 2>/dev/null" EXIT

# 读取窗口大小，避免窗口过小的时候就打开fzf导致菜单错位
# 50次循环超时
wait_timeout=50
# 循环检测终端的长和宽
while [[ $(tput cols) -lt 35 || $(tput lines) -lt 25 ]]; do
  # 每循环一次减少超时时间
  ((wait_timeout--))
  [ "$wait_timeout" -eq 0 ] && break
done

#=== FZF 主程序 ===
cliphist list | filter_clip_list | format_clip_list | add_num | fzf \
  --ansi \
  --listen "$FZF_PORT" \
  --bind "ctrl-r:reload($RELOAD_CMD)" \
  --bind "ctrl-x:execute-silent(bash -c 'cliphist delete <<< \"\$1\"' -- {})+reload($RELOAD_CMD)" \
  --bind "alt-x:execute-silent(bash -c 'gio trash \"$HOME/.cache/cliphist/db\" 2>/dev/null || rm -f \"$HOME/.cache/cliphist/db\"; [ \"\$ENABLE_ICAT\" = \"1\" ] && printf \"\033_Ga=d\033\\\\\\\\\" > /dev/tty')+reload($RELOAD_CMD)" \
  --bind "ctrl-o:execute-silent(bash -c 'open_selection \"\$1\"' -- {})" \
  --bind "ctrl-e:execute-silent(bash -c 'open_selection \"\$1\"' -- {})" \
  --prompt="󰅍 > " \
  --header='C^-X: Delete | Alt+X: D-All | C^-R: Reload | C^-O/E: Open | Enter/C^-F: Paste' \
  --color='header:italic:yellow,prompt:blue,pointer:blue' \
  --info=hidden \
  --no-sort \
  --layout=reverse \
  --with-nth 2.. \
  --delimiter '\t' \
  --preview-window=down:60%,wrap \
  --preview '
  # 【修复 Bug 3】：全局强制清空残留的Kitty图片！
  # 必须定向到 > /dev/tty，否则 fzf 会把图形转义符吞掉，导致图片无法被消除，出现文字和图片重叠！
  if [ "$ENABLE_ICAT" = "1" ]; then
      printf "\033_Ga=d\033\\" > /dev/tty
  fi

  # 获取当期剪贴版项目的id 
  id=$(echo {} | cut -f1)
  content=$(echo {} | cut -f2-)
  tmp_preview=$(mktemp /dev/shm/shorinclip_preview.XXXXXX 2>/dev/null || mktemp)
  trap "rm -f \"\$tmp_preview\" 2>/dev/null" EXIT

  echo {} | cliphist decode 2>/dev/null > "$tmp_preview"
  # 通过decode数据获取mimetype
  mimeType=$(file -b --mime-type "$tmp_preview")
  # 获取文件后缀名
  ext="${mimeType#*/}"

  # 通过mimetype判断数据/类型
  # 如果是二进制图片
  if [[ $mimeType =~ image ]]; then
        # 生成缓存文件
        img_hash=$(hash_calc < "$tmp_preview")
        cache_file="$CACHE_DIR/$img_hash.$ext" 
        if [ ! -f "$cache_file" ]; then
            cp "$tmp_preview" "$cache_file"
        fi
        _preview "$cache_file"
   
  # 如果是qq复制出来的html链接
  elif [ "$mimeType" = "text/html" ] && grep -a -q "QQ" "$tmp_preview"; then
        # 获取html数据中的图片路径，加入容错
        qq_img_file=$(grep -a -oP "^<img sr[c]=\"file://\K[^\"]+" "$tmp_preview" | head -n 1)
        if [ -n "$qq_img_file" ] && [ -f "$qq_img_file" ]; then
            _preview "$qq_img_file"
        else
            cat "$tmp_preview"
        fi

  # 如果是QQ复制出来的富文本视频 (规避自匹配 bug)
  elif grep -a -q "QQRich[E]ditFormat" "$tmp_preview" && grep -a -q "EditElement type=\"[7]\"" "$tmp_preview"; then
        qq_vid_file=$(grep -a -oP "filepat[h]=\"\K[^\"]+" "$tmp_preview" | head -n 1)
        # 如果确实提取到了真实文件才进行处理，否则当成纯文本输出
        if [ -n "$qq_vid_file" ] && [ -f "$qq_vid_file" ]; then
              _preview_video "$qq_vid_file"
        else
              # 匹配错误或文件不存在，退回纯文本预览
              cat "$tmp_preview"
        fi

  # 如果是复制文件获取的绝对路径
  elif path=$(cat "$tmp_preview") && [[ "$path" == /* ]]; then
        # 获取路径代表的文件的mimetype
        path_mime=$(file -b --mime-type "$path")
        # 如果是图片的话 
        if [[ $path_mime =~ image ]]; then
              _preview "$path"
        # 如果是视频的话 
        elif [[ "$path_mime" =~ video ]]; then
              _preview_video "$path"
        else
              echo "$path"
        fi
  # 如果是file:///开头的协议路径
  elif decoded=$(cat "$tmp_preview") && [[ "$decoded" == file://* ]]; then
        # 获取文件路径
        raw_path="${decoded#file://}"
        raw_path=$(printf "%b" "${raw_path//%/\\x}")
        mime_raw_path=$(file -b --mime-type "$raw_path")

        # 如果是图片的话
        if [[ $mime_raw_path =~ image ]]; then
            _preview "$raw_path" 
        # 如果是视频的话
        elif [[ $mime_raw_path =~ video  ]]; then
            _preview_video "$raw_path"
        fi

  # 其他数据
  else
        # 直接预览 (移除了旧版此处无用的清理代码，因为已在顶部统一清理)
        cat "$tmp_preview"
  fi
  ' \
  --bind "enter:execute-silent(bash -c 'copy_selection \"\$1\"' -- {})+accept"\
  --bind "ctrl-f:execute-silent(bash -c 'copy_selection \"\$1\"' -- {})+accept"\
  --bind "ctrl-l:execute-silent(bash -c 'copy_selection \"\$1\"' -- {})+accept"\
  --bind "ctrl-h:execute-silent(bash -c 'copy_selection \"\$1\"' -- {})+accept"


# 粘贴已经绑定到了fzf的enter键，脚本会自动退出，必须写在fzf的按键绑定，否则wl-copy会导致浮动终端卡住（niri下）。
